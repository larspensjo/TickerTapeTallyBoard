{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend build",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Backend run",
      "type": "shell",
      "command": "cargo run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "none",
      "problemMatcher": [
        "$rustc"
      ],
      "dependsOn": "Backend build"
    },
    {
      "label": "Backend test",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test",
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Backend clippy",
      "type": "shell",
      "command": "cargo clippy --all-targets -- -D warnings",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "problemMatcher": [
        "$rustc"
      ]
    },
    {
      "label": "Backend format",
      "type": "shell",
      "command": "cargo fmt",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Backend clean",
      "type": "shell",
      "command": "cargo clean",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Frontend install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Frontend dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Frontend build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "Frontend check",
      "type": "shell",
      "command": "npm run check",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "Frontend format",
      "type": "shell",
      "command": "npm run fmt",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "Check all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Backend build",
        "Backend clippy",
        "Frontend check",
        "Frontend build"
      ],
      "problemMatcher": []
    },
    {
      "label": "Format all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Backend format",
        "Frontend format"
      ],
      "problemMatcher": []
    }
  ]
}
